{
  "name": "superhome-functions",
  "version": "1.0.0",
  "description": "Firebase Cloud Functions for SuperHome",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "18"
  },
  "dependencies": {
    "@types/uuid": "^11.0.0",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^4.5.0",
    "geofire-common": "^6.0.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.3"
  },
  "private": true
}
