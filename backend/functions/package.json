{
  "name": "functions",
  "scripts": {
    "build": "tsc",
    "serve": "bun run build && firebase emulators:start --only functions",
    "shell": "bun run build && firebase functions:shell",
    "start": "bun run shell",
    "deploy": "firebase deploy --only functions --project limited-edition-prod",
    "logs": "firebase functions:log --project limited-edition-prod",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^5.1.0",
    "@google-cloud/functions-framework": "^3.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0"
  }
}
